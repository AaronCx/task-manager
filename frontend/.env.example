# Task Manager API base URL (Spring Boot backend)
# For local dev with Vite proxy: leave empty or use /api
# For Vercel: set to your Render backend URL, e.g. https://taskflow-api.onrender.com/api
VITE_API_URL=/api

# Notifications API base URL (Notification microservice)
# For local dev with Vite proxy: leave empty or use /api
# For Vercel: set to your Render notifications URL, e.g. https://taskflow-notifications.onrender.com/api
VITE_NOTIFICATIONS_URL=/api
